{
  "$schema": "./cloudflare/node_modules/wrangler/config-schema.json",
  "name": "sub-store-cloudflare",
  "main": "cloudflare/src/index.ts",
  "workers_dev": true,
  "compatibility_date": "2026-06-28",
  "assets": {
    "directory": "frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "secrets": {
    "required": [
      "SUB_STORE_ADMIN_TOKEN",
      "SUB_STORE_PUBLIC_DOWNLOAD_TOKEN"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sub-store-cloudflare",
      "database_id": "87d3c225-4b6f-42d3-91c7-f21d2d2526c3",
      "migrations_dir": "cloudflare/migrations"
    }
  ],
  "vars": {
    "SUB_STORE_APP_NAME": "Sub-Store Cloudflare",
    "SUB_STORE_PUBLIC_DOWNLOAD_HOSTS": "1"
  }
}
